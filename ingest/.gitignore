# --- Node / pnpm / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# build output
dist/
build/
.vite/
.turbo/
.parcel-cache/

# --- Tauri / Rust ---
# Rust build output (also used by Tauri)
target/
**/target/

# Rust build dirs (some tools emit plain `debug/`)
debug/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these (debug info)
*.pdb

# Generated by cargo mutants (mutation testing data)
**/mutants.out*/

# Tauri local tooling/state
src-tauri/.tauri/

# --- Python ---
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- OS / Editor ---
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kumiho Ingest Studio",
  "version": "0.1.0",
  "identifier": "com.kumiho.ingest.studio",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../ingest-studio-ui/dist"
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "capabilities": ["main"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Kumiho Ingest Studio",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../../../worker", "../../../python"],
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/KumihoIO/kumiho-apps/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}

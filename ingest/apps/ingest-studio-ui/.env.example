# Firebase web app configuration for the Ingest Studio UI.
# These VITE_* values are exposed to the client at build time and are NOT
# secrets (Firebase web API keys are project identifiers; access is enforced
# by Firebase Security Rules, authorized domains, and App Check).
# Copy this file to `.env` and fill in your own Firebase project values.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
